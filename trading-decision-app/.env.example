# =========================================================================
# Trading Decision App — environment template
# Copy to ".env" and fill in. Loaded at server startup; the front-end
# /api/config endpoint exposes the defaults to the form.
# =========================================================================

# ---- LLM provider API keys ---------------------------------------------
# Set at least one to use LIVE mode. Otherwise the app stays in DEMO mode
# (scripted events, no real LLM calls).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=          # Qwen 通义千问
MOONSHOT_API_KEY=           # Kimi (Moonshot)
ZHIPU_API_KEY=              # 智谱 GLM

# ---- translation layer --------------------------------------------------
# Internal Bull/Bear and Risk debates run in English (TradingAgents design
# choice — preserves reasoning quality). Our backend translates them to
# Chinese in the background using one of the keys above.
#
# Provider preference order (auto-pick the first one with a key):
#   deepseek → qwen → glm → kimi → openai
#
# Override with these:
TRANSLATION_PROVIDER=        # deepseek | qwen | glm | kimi | openai
TRANSLATION_MODEL=           # any model id; defaults to the provider's quick model

# ---- form defaults ------------------------------------------------------
DEFAULT_LLM_PROVIDER=openai  # openai | anthropic | google | deepseek | qwen | kimi | glm
DEFAULT_DEEP_LLM=            # any model id, e.g. gpt-5.5, claude-opus-4-7, deepseek-v4-pro
DEFAULT_QUICK_LLM=           # any model id, e.g. gpt-5.5-mini, claude-haiku-4-6
DEFAULT_RESEARCH_DEPTH=1     # 1..5
DEFAULT_OUTPUT_LANGUAGE=Chinese  # Chinese | English
DEFAULT_TICKER=NVDA
DEFAULT_INSTRUMENT=stock
DEFAULT_RISK_TOLERANCE=3     # 1..5

# ---- TradingAgents (only used by LIVE mode) ----------------------------
# Where TradingAgents writes logs and caches; falls back to ~/.tradingagents
# TRADINGAGENTS_RESULTS_DIR=
# TRADINGAGENTS_CACHE_DIR=
